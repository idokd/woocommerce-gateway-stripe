includes:
	- phpstan-baseline.neon
	- vendor/szepeviktor/phpstan-wordpress/extension.neon

parameters:
	tmpDir: phpstan-tmp
	level: 8
	phpVersion: 70400
	paths:
		- woocommerce-gateway-stripe.php
		- includes/
	bootstrapFiles:
		- vendor/autoload.php
		- vendor/php-stubs/woocommerce-stubs/woocommerce-stubs.php
	scanDirectories:
		- phpstan-stubs
	treatPhpDocTypesAsCertain: false
	parallel:
		maximumNumberOfProcesses: 4
	excludePaths:
		# Exclude Agentic Commerce files that depend on external WooCommerce ProductFeed plugin
		- includes/agentic-commerce/class-wc-stripe-agentic-commerce-integration.php
		- includes/agentic-commerce/class-wc-stripe-agentic-commerce-files-api-delivery.php
	ignoreErrors:
		-
			identifier: missingType.iterableValue
